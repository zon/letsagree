FROM docker.io/library/golang:1.26-alpine AS builder

WORKDIR /build

COPY go.mod go.sum* ./
RUN go mod download

COPY . .

ARG VERSION=dev
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags "-X main.version=${VERSION}" -o /backend ./cmd/server

FROM docker.io/library/alpine:3.21

RUN apk add --no-cache ca-certificates

COPY --from=builder /backend /backend

EXPOSE 8080

ENTRYPOINT ["/backend"]